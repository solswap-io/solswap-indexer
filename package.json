{
  "name": "solswap-indexer",
  "version": "0.1.0",
  "private": true,
  "description": "Spot analytics indexer for Solswap on Solana",
  "main": "dist/index.js",
  "type": "commonjs",
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "test": "tsx src/scripts/smoke.ts && tsx src/scripts/deployment-manifest-test.ts && tsx src/scripts/production-smoke-adversarial-test.ts",
    "smoke:production": "tsx src/scripts/production-smoke.ts",
    "audit:deployment-evidence": "bash scripts/audit-deployment-evidence.sh",
    "test:deployment-evidence-audit": "bash scripts/test-deployment-evidence-audit.sh"
  },
  "dependencies": {
    "@solana/web3.js": "^1.98.4",
    "fastify": "^5.8.5",
    "pino": "^10.3.0"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "overrides": {
    "fast-uri": "^4.0.0",
    "uuid": "^11.1.1",
    "ws": "^8.21.0"
  }
}
